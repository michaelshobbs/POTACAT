{
  "name": "potacat",
  "version": "1.8.5",
  "description": "Amateur radio spot aggregator with CAT control, QSO logging, and panadapter integration",
  "author": {
    "name": "Casey Stanton",
    "email": "casey@potacat.com"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-ft8": "cd lib/ft8_native && node-gyp rebuild",
    "build-freedv": "cd lib/freedv_native && node-gyp rebuild",
    "build-rade": "node scripts/build-rade.js",
    "build-natives": "node scripts/build-natives.js",
    "build-icon": "node scripts/build-icon.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:linux:deb": "electron-builder --linux deb",
    "dist:linux:rpm": "electron-builder --linux rpm",
    "dist:linux:appimage": "electron-builder --linux AppImage",
    "release": "node scripts/release.js",
    "launcher": "node scripts/launcher.js",
    "test": "node test/rig-test.js && node test/websdr-test.js && node test/ragchew-test.js && node test/echocat-protocol.test.js && node test/jtcat-test.js && node test/sstv-test.js && node test/sstv-quality-test.js",
    "test:websdr-live": "node test/websdr-test.js",
    "launcher:install": "node scripts/launcher-install.js",
    "launcher:uninstall": "node scripts/launcher-install.js --uninstall",
    "fetch:cloudflared": "node scripts/fetch-cloudflared.js",
    "predist:win": "node scripts/fetch-cloudflared.js --platform=win",
    "predist:mac": "node scripts/fetch-cloudflared.js --platform=mac --arch=arm64",
    "predist:linux": "node scripts/fetch-cloudflared.js --platform=linux --arch=x64"
  },
  "build": {
    "appId": "com.waffleslop.potacat",
    "productName": "POTACAT",
    "icon": "assets/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "preload-popout.js",
      "preload-qso-popout.js",
      "preload-actmap-popout.js",
      "preload-spots-popout.js",
      "preload-cluster-popout.js",
      "preload-jtcat-popout.js",
      "preload-vfo-popout.js",
      "preload-remote-audio.js",
      "preload-sstv-popout.js",
      "preload-bandspread-popout.js",
      "preload-pair-popout.js",
      "preload-prop-popout.js",
      "preload-log-popout.js",
      "preload-conditions-popout.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "assets/icon-256.png",
      "assets/icon-light.png",
      "assets/cty.dat",
      "scripts/test-alsa.js",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/sharp/**/*"
    ],
    "asarUnpack": [
      "lib/ft4/**/*",
      "lib/ft2/**/*",
      "lib/ft8_native/**/*",
      "lib/freedv_native/**/*",
      "lib/rade_native/**/*",
      "lib/alsa_native/**/*",
      "lib/alsa.js",
      "scripts/test-alsa.js",
      "node_modules/@discordjs/opus/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "extraResources": [
        {
          "from": "resources/cloudflared/win/cloudflared.exe",
          "to": "cloudflared.exe"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POTACAT",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null,
      "entitlements": null,
      "entitlementsInherit": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "POTACAT needs microphone access for ECHOCAT remote audio.",
        "NSCameraUsageDescription": "POTACAT does not use the camera but WebRTC requires this permission."
      },
      "extraResources": [
        {
          "from": "resources/cloudflared/mac/cloudflared",
          "to": "cloudflared"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "extraResources": [
        {
          "from": "resources/cloudflared/linux/cloudflared",
          "to": "cloudflared"
        }
      ]
    },
    "protocols": [
      {
        "name": "POTACAT Protocol",
        "schemes": [
          "potacat"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "assets/hamlib",
        "to": "hamlib",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/launcher.js",
        "to": "scripts/launcher.js"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Waffleslop",
      "repo": "POTACAT"
    }
  },
  "devDependencies": {
    "cmake-js": "^8.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.7.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.8.3",
    "ft8js": "^0.0.3",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.4",
    "serialport": "^13.0.0",
    "sql.js": "^1.14.0",
    "ws": "^8.19.0"
  }
}
